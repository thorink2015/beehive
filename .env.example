# Copy this file to ".env" and fill in your real values.
# The real .env is gitignored and will NEVER be committed.
#
# Where to get these:
#   beehiiv dashboard -> Settings -> Workspace Settings -> API
#   - Create New API Key (you must be Owner or Admin). Copy it immediately;
#     beehiiv only shows it once.
#   - Publication ID is on the same screen (use the API v2 value).
#   - Template ID: Start Writing -> My templates -> Edit a template ->
#     the ID is in the URL after /posts/.

BEEHIIV_API_KEY=bh-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional — only needed if you create posts via the API (Enterprise plan).
BEEHIIV_POST_TEMPLATE_ID=
